# Postgres
DATABASE_URL=postgresql+psycopg://trade_chaser:trade_chaser@localhost:5432/trade_chaser

# JWT
SECRET_KEY=change-this-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (comma separated origins)
CORS_ORIGINS=http://localhost:5173

# External APIs (선택 - 없으면 뉴스/브리핑 생성 관련 기능은 스텁으로 동작)
FINNHUB_API_KEY=
ANTHROPIC_API_KEY=
POLYGON_API_KEY=

# Startup bootstrap
# 로컬 uvicorn 실행에서도 stocks 테이블이 비어 있거나 시드 10개 수준이면
# 서버 시작 직후 FINNHUB_API_KEY로 미국 보통주 전체 import를 백그라운드 시도
AUTO_IMPORT_US_STOCKS=true
AUTO_IMPORT_US_STOCKS_THRESHOLD=100

# Finnhub 뉴스 관련성 점수 필터. false로 바꾸고 프로세스/컨테이너를 재생성하면
# 기존 최신순 수집으로 즉시 롤백됩니다.
ENABLE_NEWS_RELEVANCE_FILTER=true
NEWS_RELEVANCE_MIN_SCORE=4
NEWS_RELEVANCE_MIN_ARTICLES=3

# Overall market news: CNBC RSS first, Finnhub general news as fallback.
ENABLE_CNBC_MARKET_RSS=true
CNBC_MARKET_NEWS_LOOKBACK_HOURS=24
CNBC_MARKET_NEWS_PER_FEED=10
CNBC_MARKET_NEWS_LIMIT=40
CNBC_MARKET_NEWS_MIN_ARTICLES=12

# 전체 시황·관심 섹터·관심종목 브리핑 하루 4회 자동 갱신 (한국시간)
ENABLE_SCHEDULER=True
REFRESH_HOURS_KST=2,5,14,22
